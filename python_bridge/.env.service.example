# Python bridge service configuration
HOST=127.0.0.1
PORT=8000
LOG_LEVEL=info

# Optional shared secret expected from the TypeScript bridge
# Leave empty to disable API key validation
PYTHON_AGENT_API_KEY=

# Runtime selection: mock | langchain | llamaindex | hybrid
AGENT_BACKEND=mock

# Future LLM / agent framework settings
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
COHERE_API_KEY=

# LangChain / LlamaIndex future settings
LANGCHAIN_MODEL=groq:qwen/qwen3-32b
LLAMAINDEX_MODEL=
LLAMAINDEX_DOCS_DIR=./docs/rag/malay
HYBRID_RAG_LANGUAGE=Malay
HYBRID_RAG_TOP_K=3
DEFAULT_EMBEDDING_MODEL=
DEFAULT_SYSTEM_PROMPT=You are a helpful assistant on Telegram and WhatsApp. Be concise, clear, and safe.
LANGCHAIN_TIMEOUT_SECONDS=25

# Media and processing settings
MEDIA_ROOT=./media
TEMP_DIR=./tmp
MAX_UPLOAD_MB=50

# Optional feature flags for future multimodal processing
ENABLE_AUDIO_TRANSCRIPTION=false
ENABLE_IMAGE_ANALYSIS=false
ENABLE_DOCUMENT_EXTRACTION=false
ENABLE_VIDEO_ANALYSIS=false
