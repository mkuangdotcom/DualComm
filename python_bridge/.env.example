# LEGACY: This file belongs to an earlier scaffold and is not used by the
# current python_bridge service. Use .env.service.example instead.
# Python Bridge App
APP_NAME=whatsapp-llm-python-bridge
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# Security
WEBHOOK_SECRET=
ALLOWED_WEBHOOK_EVENTS=MESSAGES_UPSERT,CONNECTION_UPDATE,QRCODE_UPDATED

# Evolution API
EVOLUTION_API_BASE_URL=http://localhost:8080
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=
EVOLUTION_WEBHOOK_URL=http://localhost:8000/webhooks/evolution
EVOLUTION_WEBHOOK_ENABLED=true
EVOLUTION_WEBHOOK_BY_EVENTS=false
EVOLUTION_WEBHOOK_BASE64=false

# Agent Runtime
AGENT_PROVIDER=mock
AGENT_REQUEST_TIMEOUT_SECONDS=60

# LangChain / LlamaIndex readiness
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
COHERE_API_KEY=

# Default model routing
DEFAULT_CHAT_MODEL=
DEFAULT_EMBEDDING_MODEL=

# Media handling
MEDIA_STORAGE_BACKEND=local
MEDIA_STORAGE_PATH=./data/media
MEDIA_DOWNLOAD_ENABLED=true
MEDIA_MAX_FILE_SIZE_MB=25
MEDIA_PRESERVE_BASE64=false

# Optional preprocessing hooks
ENABLE_AUDIO_TRANSCRIPTION=false
ENABLE_IMAGE_ANALYSIS=false
ENABLE_DOCUMENT_EXTRACTION=false

# Future external Python runtime / microservice
EXTERNAL_AGENT_BASE_URL=
EXTERNAL_AGENT_API_KEY=

# Conversation/session behavior
SESSION_MEMORY_BACKEND=memory
SESSION_TTL_SECONDS=86400
DEFAULT_SYSTEM_PROMPT=You are a helpful assistant on WhatsApp. Be concise, clear, and safe.

# Development flags
AUTO_CONFIGURE_EVOLUTION_WEBHOOK=false
MARK_MESSAGES_AS_READ=false
SEND_TYPING_INDICATOR=true
